# Storage
ML_STORAGE_BACKEND=chroma
ML_METADATA_BACKEND=sqlite
ML_CHROMA_PATH=./data/chroma
ML_SQLITE_PATH=./data/memory.db
# ML_QDRANT_URL=http://localhost:6333
# ML_QDRANT_API_KEY=
ML_QDRANT_COLLECTION=memory_layer
# ML_POSTGRES_URL=postgresql+asyncpg://user:pass@localhost/memory_layer

# Embedding
ML_EMBEDDING_MODEL=all-MiniLM-L6-v2
ML_EMBEDDING_DEVICE=cpu
ML_EMBEDDING_BATCH_SIZE=32
ML_EMBEDDING_CACHE=true

# Memory behavior
ML_DEFAULT_TOKEN_BUDGET=2000
ML_DEFAULT_TOP_K=5
ML_IMPORTANCE_THRESHOLD=0.3
ML_COMPRESSION_THRESHOLD=10
ML_RERANKER_ENABLED=false
ML_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ML_MAX_CHUNK_TOKENS=300
ML_MIN_CHUNK_TOKENS=50

# Compression
# ML_COMPRESSION_MODEL=claude-haiku-4-5-20251001
# ML_COMPRESSION_API_KEY=
# ML_COMPRESSION_API_BASE=
ML_COMPRESSION_SESSIONS=5

# API server
# ML_API_KEY=
ML_HOST=0.0.0.0
ML_PORT=8000
ML_WORKERS=1
ML_CORS_ORIGINS=*
ML_RATE_LIMIT_SAVE=100
ML_RATE_LIMIT_RECALL=200

# Observability
ML_LOG_LEVEL=INFO
ML_LOG_FORMAT=text
ML_LOG_SANITIZE=false
ML_METRICS_ENABLED=false
